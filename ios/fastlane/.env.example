# App Store Connect API Key
# Get these from: https://appstoreconnect.apple.com > Users and Access > Integrations

# Key ID (10 characters, shown next to key name)
ASC_KEY_ID=YOUR_KEY_ID

# Issuer ID (UUID shown at top of API keys page)
ASC_ISSUER_ID=YOUR_ISSUER_ID

# For LOCAL development: Path to your .p8 file (relative to fastlane directory)
ASC_KEY_PATH=./private_keys/AuthKey_XXXXXXXXXX.p8

# For CI/CD: Base64-encoded .p8 content (not needed locally)
# Generate with: base64 -i AuthKey_XXXXXXXXXX.p8
# ASC_KEY_CONTENT=

# Match Certificate Management
MATCH_GIT_URL=https://github.com/ciagent-techstackapps/ios-certs.git

# Encryption password (create a strong password and save it securely)
# This encrypts certificates in the git repository
MATCH_PASSWORD=YOUR_MATCH_ENCRYPTION_PASSWORD
